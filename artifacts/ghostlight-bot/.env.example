# ─── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_CHANNEL_ID=
# Set to true to only respond when directly @mentioned
DISCORD_RESPOND_TO_MENTIONS_ONLY=false

# ─── LLM / OpenRouter ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# Optional: override individual model per capability
# CHAT_LLM_MODEL=openai/gpt-4o
# SUMMARY_LLM_MODEL=openai/gpt-4o-mini
# EMBEDDING_LLM_MODEL=openai/text-embedding-3-small
# TRANSCRIPTION_LLM_MODEL=google/gemini-2.5-flash

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=

# ─── Persona ───────────────────────────────────────────────────────────────────
CHAT_PROMPT_PERSONA_NAME=
CHAT_PROMPT_USER_NAME=the user
CHAT_PROMPT_PERSONA_PROFILE=
CHAT_PROMPT_TONE_GUIDELINES=
CHAT_PROMPT_USER_PROFILE=
CHAT_PROMPT_COMPANION_PURPOSE=
CHAT_PROMPT_BOUNDARY_RULES=

# ─── Chat Settings ─────────────────────────────────────────────────────────────
CHAT_HISTORY_LIMIT=20
CHAT_INCLUDE_TIME_CONTEXT=true
CHAT_TIMEZONE=UTC

# ─── Memory ────────────────────────────────────────────────────────────────────
MEMORY_USER_SCOPE=user
MEMORY_LOOKUP_ENABLED=false
MEMORY_CURATOR_ENABLED=false
MEMORY_TIMELINE_DAILY_WINDOW_DAYS=14

# ─── Qdrant (optional — for vector memory search) ──────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
# Vector memory collection name (use a fresh name per Qdrant instance).
QDRANT_COLLECTION=ghostlight-memory

# ─── Image Generation (optional) ───────────────────────────────────────────────
IMAGE_GENERATION_ENABLED=false
# GETIMG_API_KEY=

# ─── Audio / TTS (optional) ────────────────────────────────────────────────────
AUDIO_TTS_ENABLED=false
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# ─── Spotify (optional) ────────────────────────────────────────────────────────
SPOTIFY_ENABLED=false
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=

# ─── Heartbeat (proactive messaging) ───────────────────────────────────────────
HEARTBEAT_ENABLED=true
HEARTBEAT_DAILY_CAP=5
HEARTBEAT_QUIET_HOURS_ENABLED=true
HEARTBEAT_QUIET_HOURS_START=22:00
HEARTBEAT_QUIET_HOURS_END=08:00
# Legacy METRONOME_* names still work — the bot reads both during transition.

# ─── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ─── Object Storage (optional — for images/audio bucket) ───────────────────────
# Option A — explicit names (always work, any S3-compatible provider):
BUCKET=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
ENDPOINT=
REGION=auto
# Option B — Railway / Tigris: when you add a Tigris bucket to your Railway
# project it auto-injects the variables below.  The app reads them as fallbacks
# so no extra wiring is needed — just provision the bucket and redeploy.
# AWS_ACCESS_KEY_ID=       (injected by Railway/Tigris)
# AWS_SECRET_ACCESS_KEY=   (injected by Railway/Tigris)
# AWS_ENDPOINT_URL_S3=     (injected by Railway/Tigris, e.g. https://fly.storage.tigris.dev)
# AWS_REGION=              (injected by Railway/Tigris)
# BUCKET_NAME=             (injected by Railway/Tigris)

# ─── Ghostlight build (optional version/tag overrides) ─────────────────────────
# Surfaced in the admin UI as the running build version/tag.
# GHOSTLIGHT_VERSION=
# GHOSTLIGHT_IMAGE_TAG=

# ─── Developer / Diagnostic ────────────────────────────────────────────────────
# JC (Discord ID 608669463427940362) is hardcoded as a developer user.
# Any channel with "test" in the name triggers developer mode for these users:
# persona is dropped, engine preludes are skipped, "show logs" returns log dumps.
# DEVELOPER_USER_IDS=   # optional: comma-separated extra Discord user IDs

# Railway API integration for on-demand log dumps ("show logs" in a test channel).
# RAILWAY_TOKEN is a Railway account API token (https://railway.app/account/tokens).
# RAILWAY_SERVICE_ID is shown in the Railway dashboard under your service settings.
# RAILWAY_ENVIRONMENT_ID is auto-injected by Railway — only set this manually if needed.
# RAILWAY_TOKEN=
# RAILWAY_SERVICE_ID=
# RAILWAY_ENVIRONMENT_ID=

# ─── Misc ──────────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
