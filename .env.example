# ─── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_CHANNEL_ID=
DISCORD_RESPOND_TO_MENTIONS_ONLY=false

# ─── LLM / OpenRouter ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# Optional: override individual model per capability
# CHAT_LLM_MODEL=openai/gpt-4o
# SUMMARY_LLM_MODEL=openai/gpt-4o-mini
# EMBEDDING_LLM_MODEL=openai/text-embedding-3-small
# TRANSCRIPTION_LLM_MODEL=openai/whisper-1

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=

# ─── Chat Settings ─────────────────────────────────────────────────────────────
CHAT_HISTORY_LIMIT=20
CHAT_INCLUDE_TIME_CONTEXT=true
CHAT_TIMEZONE=UTC

# ─── Audio / TTS (optional) ────────────────────────────────────────────────────
AUDIO_TTS_ENABLED=false
# AUDIO_TTS_PROVIDER=elevenlabs   # allowed values: elevenlabs | fish_audio | none

# ElevenLabs provider (used when AUDIO_TTS_PROVIDER=elevenlabs or unset)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Fish Audio provider (used when AUDIO_TTS_PROVIDER=fish_audio or FISH_AUDIO_ENABLED=true)
# FISH_AUDIO_ENABLED=false         # set true to default provider to Fish Audio
# FISH_AUDIO_API_KEY=
# FISH_AUDIO_VOICE_ID=             # Fish Audio reference_id for the voice
# FISH_AUDIO_MODEL_ID=             # optional Fish Audio model override (leave blank for default)

# ─── Object Storage (optional — for audio bucket) ──────────────────────────────
BUCKET=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
ENDPOINT=
REGION=auto


# ─── Alive Layer / Inner Life Routing ──────────────────────────────────────────
# Defaults match Dante's production channel setup. Set explicitly in Railway if
# you want the values visible/editable or if the channel IDs change.
ALIVE_ENABLED=true
# Keep outbound proactive sends gated unless you are ready for unprompted messages.
ALIVE_UNPROMPTED_ENABLED=false
# Required only when ALIVE_UNPROMPTED_ENABLED=true.
ALIVE_TARGET_CHANNEL_ID=
ALIVE_TICK_INTERVAL_MS=900000
ALIVE_ABSENCE_THRESHOLD_MS=14400000
ALIVE_DAILY_REACH_OUT_CAP=3
ALIVE_COOLDOWN_MS=7200000
ALIVE_QUIET_HOURS_START=23
ALIVE_QUIET_HOURS_END=7
ALIVE_TIMEZONE=UTC

# Private autonomy / inner-life stream.
INNER_LIFE_AUTONOMY_CHANNEL_ID=1513266945577717881
# Dante self-check / diagnostics stream.
INNER_LIFE_DIAGNOSTIC_CHANNEL_ID=1520510624617201804
INNER_LIFE_SELF_CHECK_ENABLED=true
# 24-hour clock, local server time: morning, noon, night.
INNER_LIFE_SELF_CHECK_HOURS=8,12,21

# ─── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ─── Developer / Diagnostic ────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
# Dashboard phone calls (browser STT + Kokoro Web TTS; no paid STT required)
CALLS_ENABLED=true
STT_PROVIDER=browser
TTS_PROVIDER=kokoro_web
KOKORO_API_URL=
KOKORO_VOICE=
KOKORO_FORMAT=wav
CALL_CONTEXT_MODE=light
HANDS_FREE_SILENCE_MS=1200
CALL_MAX_UTTERANCE_SECONDS=30
